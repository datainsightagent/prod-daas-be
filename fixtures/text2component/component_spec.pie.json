{
  "spec_version": 2,
  "title": "Inquiry Share by Source",
  "type": "pie",
  "query": {
    "sql": "SELECT source, COUNT(*) AS count FROM inquiries GROUP BY source",
    "params": {}
  },
  "layout": { "x": 0, "y": 0, "w": 4, "h": 4 },
  "data_map": {
    "dimension": "source",
    "measure": "count"
  },
  "config": {
    "show_legend": true,
    "show_percentages_in_legend": true,
    "minimum_slice_percentage": 2.5,
    "colors": {
      "Word of Mouth": "#5b9bd5",
      "Facebook": "#9dc3e6",
      "Google": "#2e75b6"
    }
  }
}
