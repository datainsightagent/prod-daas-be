{
  "spec_version": 2,
  "id": "f8d33b74-7eee-46b8-b3f7-56246b4c7a07",
  "title": "How many products exist in each category, aggregated by cate",
  "type": "table",
  "query": {
    "sql": "SELECT c.title AS category, COUNT(p.id) AS product_count\nFROM products p\nJOIN categories c ON p.category_id = c.id\nGROUP BY c.title;",
    "params": {}
  },
